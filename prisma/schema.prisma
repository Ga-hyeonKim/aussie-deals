// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Store {
  WOOLWORTHS
  COLES
}

model Product {
  id              String   @id @default(cuid())
  store           Store
  name            String
  brand           String?
  category        String
  unit            String?
  originalPrice   Float?
  salePrice       Float
  discountPercent Int?
  imageUrl        String?
  validFrom       DateTime
  validTo         DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  cartItems       CartItem[]

  @@unique([store, name, validFrom])
  @@index([store, validFrom, validTo])
}

model StoreProduct {
  id           String        @id @default(cuid())
  store        Store
  name         String
  brand        String?
  category     String
  unit         String?
  price        Float
  imageUrl     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  favorites    Favorite[]
  priceHistory PriceHistory[]

  @@unique([store, name])
  @@index([store, category])
  @@map("store_products")
}

model PriceHistory {
  id             String       @id @default(cuid())
  storeProductId String       @map("store_product_id")
  price          Float
  isOnSale       Boolean      @default(false)
  recordedAt     DateTime     @default(now())

  storeProduct   StoreProduct @relation(fields: [storeProductId], references: [id], onDelete: Cascade)

  @@index([storeProductId, recordedAt])
  @@map("price_history")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  accounts      Account[]
  sessions      Session[]
  favorites     Favorite[]
  cartItems     CartItem[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Favorite {
  id             String       @id @default(cuid())
  userId         String       @map("user_id")
  storeProductId String       @map("store_product_id")
  createdAt      DateTime     @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeProduct StoreProduct @relation(fields: [storeProductId], references: [id], onDelete: Cascade)

  @@unique([userId, storeProductId])
  @@map("favorites")
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("cart_items")
}
